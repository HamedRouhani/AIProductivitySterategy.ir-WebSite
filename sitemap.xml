<?php
// ========================================
// فایل: sitemap.xml
// ========================================
// برای استفاده، این فایل را در ریشه وبسایت قرار دهید
// و از طریق .htaccess به عنوان sitemap.xml نمایش دهید
// یا به صورت مستقیم از sitemap.php استفاده کنید

header('Content-Type: application/xml; charset=utf-8');

require_once 'includes/db.php';

$baseUrl = 'https://' . $_SERVER['HTTP_HOST'];

// صفحات استاتیک
$staticPages = [
    ['loc' => '/', 'priority' => '1.0', 'changefreq' => 'daily'],
    ['loc' => '/about', 'priority' => '0.8', 'changefreq' => 'weekly'],
    ['loc' => '/contact', 'priority' => '0.7', 'changefreq' => 'monthly'],
    ['loc' => '/login', 'priority' => '0.3', 'changefreq' => 'yearly'],
];

// دریافت تمام پست‌ها
$posts = $pdo->query("
    SELECT id, slug, title, created_at, updated_at 
    FROM posts 
    WHERE status = 'published'
    ORDER BY updated_at DESC
")->fetchAll();

// دریافت تمام دسته‌بندی‌ها
$menus = $pdo->query("
    SELECT id, title 
    FROM menus 
    ORDER BY id ASC
")->fetchAll();

echo '<?xml version="1.0" encoding="UTF-8"?>';
?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1"
        xmlns:news="http://www.google.com/schemas/sitemap-news/0.9">
    
    <!-- ======================================== -->
    <!-- صفحات استاتیک -->
    <!-- ======================================== -->
    <?php foreach ($staticPages as $page): ?>
    <url>
        <loc><?= $baseUrl . $page['loc'] ?></loc>
        <priority><?= $page['priority'] ?></priority>
        <changefreq><?= $page['changefreq'] ?></changefreq>
    </url>
    <?php endforeach; ?>
    
    <!-- ======================================== -->
    <!-- دسته‌بندی‌ها -->
    <!-- ======================================== -->
    <?php foreach ($menus as $menu): ?>
    <url>
        <loc><?= $baseUrl ?>/category/<?= $menu['id'] ?>/<?= urlencode($menu['title']) ?></loc>
        <priority>0.7</priority>
        <changefreq>weekly</changefreq>
    </url>
    <?php endforeach; ?>
    
    <!-- ======================================== -->
    <!-- مطالب -->
    <!-- ======================================== -->
    <?php foreach ($posts as $post): ?>
    <url>
        <loc><?= $baseUrl ?>/post/<?= $post['id'] ?>/<?= urlencode($post['slug'] ?? $post['title']) ?></loc>
        <priority>0.8</priority>
        <changefreq>weekly</changefreq>
        <lastmod><?= date('Y-m-d', strtotime($post['updated_at'] ?? $post['created_at'])) ?></lastmod>
    </url>
    <?php endforeach; ?>
    
</urlset>